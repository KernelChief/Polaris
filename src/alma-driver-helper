#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
set -euo pipefail

action="${1:-}"

log() { echo "[alma-driver-helper] $*"; }

case "$action" in
  install_official)
    log "Installing AlmaLinux NVIDIA repo configuration..."
    dnf -y install almalinux-release-nvidia-driver

    log "Installing NVIDIA driver packages..."
    dnf -y install nvidia-open-kmod nvidia-driver

    log "Done. Reboot recommended."
    ;;
  install_cuda_tools)
    log "Installing nvidia-smi tooling (nvidia-driver-cuda)..."
    dnf -y install nvidia-driver-cuda
    log "Done."
    ;;
  install_cuda_stack)
    log "Installing CUDA stack (cuda)..."
    dnf -y install cuda
    log "Done."
    ;;
  load_module)
    log "Loading kernel module nvidia_drm..."
    modprobe nvidia_drm
    log "Done."
    ;;
  status)
    log "Running nvidia-smi..."
    if command -v nvidia-smi >/dev/null 2>&1; then
      nvidia-smi || true
    else
      echo "nvidia-smi not found. Install 'nvidia-driver-cuda' to get it."
      exit 3
    fi
    ;;
  install_local_rpm)
    rpm_path="${2:-}"
    if [[ -z "${rpm_path}" || ! -f "${rpm_path}" ]]; then
      echo "ERROR: RPM path missing or file not found." >&2
      exit 2
    fi
    log "Installing local RPM via dnf: ${rpm_path}"
    dnf -y install "${rpm_path}"
    log "Done."
    ;;
  remove_nvidia)
    log "Removing NVIDIA packages (pattern nvidia*)..."
    dnf -y remove 'nvidia*'
    log "Done."
    ;;
  *)
    cat >&2 <<'EOF'
Usage: alma-driver-helper <action>

Actions:
  install_official        Enable official Alma NVIDIA repos + install driver
  install_cuda_tools      Install nvidia-driver-cuda (provides nvidia-smi)
  install_cuda_stack      Install cuda
  load_module             modprobe nvidia_drm
  status                  Run nvidia-smi
  install_local_rpm <p>   Install local .rpm via dnf
  remove_nvidia           Remove packages matching nvidia*
EOF
    exit 1
    ;;
esac

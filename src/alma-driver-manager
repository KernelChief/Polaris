#!/usr/bin/env python3
# SPDX-License-Identifier: MIT

import gi
gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, GLib

import subprocess
import threading
from pathlib import Path

HELPER = "/usr/libexec/alma-driver-helper"


class AlmaDriverManager(Gtk.Window):
    def __init__(self):
        super().__init__(title="Alma Driver Manager (MVP)")
        self.set_default_size(850, 520)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        outer.set_border_width(12)
        self.add(outer)

        # Top info row
        info = Gtk.Label(
            label=(
                "NVIDIA: Install via official AlmaLinux repo method or install a local RPM.\n"
                "Actions requiring privileges will prompt for admin authentication."
            )
        )
        info.set_xalign(0)
        outer.pack_start(info, False, False, 0)

        # Buttons grid
        grid = Gtk.Grid(column_spacing=10, row_spacing=10)
        outer.pack_start(grid, False, False, 0)

        btn_install_official = Gtk.Button(label="Install NVIDIA (Official AlmaLinux Method)")
        btn_install_official.connect("clicked", lambda *_: self.run_helper(["install_official"]))
        grid.attach(btn_install_official, 0, 0, 2, 1)

        btn_install_cuda_tools = Gtk.Button(label="Install nvidia-smi tools (nvidia-driver-cuda)")
        btn_install_cuda_tools.connect("clicked", lambda *_: self.run_helper(["install_cuda_tools"]))
        grid.attach(btn_install_cuda_tools, 2, 0, 2, 1)

        btn_install_cuda = Gtk.Button(label="Install CUDA stack (cuda)")
        btn_install_cuda.connect("clicked", lambda *_: self.run_helper(["install_cuda_stack"]))
        grid.attach(btn_install_cuda, 4, 0, 2, 1)

        btn_modprobe = Gtk.Button(label="Load module (modprobe nvidia_drm)")
        btn_modprobe.connect("clicked", lambda *_: self.run_helper(["load_module"]))
        grid.attach(btn_modprobe, 0, 1, 2, 1)

        btn_status = Gtk.Button(label="Status (nvidia-smi)")
        btn_status.connect("clicked", lambda *_: self.run_helper(["status"]))
        grid.attach(btn_status, 2, 1, 2, 1)

        btn_remove = Gtk.Button(label="Remove NVIDIA packages")
        btn_remove.connect("clicked", lambda *_: self.run_helper(["remove_nvidia"]))
        grid.attach(btn_remove, 4, 1, 2, 1)

        btn_local = Gtk.Button(label="Install from local RPM…")
        btn_local.connect("clicked", self.pick_rpm_and_install)
        grid.attach(btn_local, 0, 2, 2, 1)

        btn_clear = Gtk.Button(label="Clear log")
        btn_clear.connect("clicked", lambda *_: self.set_log(""))
        grid.attach(btn_clear, 2, 2, 2, 1)

        btn_quit = Gtk.Button(label="Quit")
        btn_quit.connect("clicked", lambda *_: self.close())
        grid.attach(btn_quit, 4, 2, 2, 1)

        # Log output
        self.textview = Gtk.TextView()
        self.textview.set_editable(False)
        self.textview.set_monospace(True)
        self.textbuf = self.textview.get_buffer()

        scroller = Gtk.ScrolledWindow()
        scroller.set_hexpand(True)
        scroller.set_vexpand(True)
        scroller.add(self.textview)
        outer.pack_start(scroller, True, True, 0)

        self.append_log("Ready.\n")

        if not Path(HELPER).exists():
            self.append_log(f"\nWARNING: Helper not found at {HELPER}\n"
                            "Build/install the RPM or place helper there.\n")

    def set_log(self, text: str):
        self.textbuf.set_text(text)

    def append_log(self, text: str):
        end = self.textbuf.get_end_iter()
        self.textbuf.insert(end, text)
        mark = self.textbuf.create_mark(None, self.textbuf.get_end_iter(), True)
        self.textview.scroll_mark_onscreen(mark)

    def run_helper(self, args):
        if not Path(HELPER).exists():
            self.append_log(f"ERROR: Helper not found: {HELPER}\n")
            return

        cmd = ["pkexec", HELPER] + args
        self.append_log("\n$ " + " ".join(cmd) + "\n")

        def worker():
            try:
                proc = subprocess.Popen(
                    cmd,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.STDOUT,
                    text=True,
                    bufsize=1,
                )
                assert proc.stdout is not None
                for line in proc.stdout:
                    GLib.idle_add(self.append_log, line)
                rc = proc.wait()
                GLib.idle_add(self.append_log, f"[exit code: {rc}]\n")
                if rc == 0 and args and args[0] in ("install_official", "install_cuda_tools", "install_cuda_stack"):
                    GLib.idle_add(self.append_log, "NOTE: Reboot may be required.\n")
            except Exception as e:
                GLib.idle_add(self.append_log, f"ERROR: {e}\n")

        threading.Thread(target=worker, daemon=True).start()

    def pick_rpm_and_install(self, *_):
        dialog = Gtk.FileChooserDialog(
            title="Select an RPM file",
            parent=self,
            action=Gtk.FileChooserAction.OPEN,
        )
        dialog.add_buttons(
            Gtk.STOCK_CANCEL, Gtk.ResponseType.CANCEL,
            Gtk.STOCK_OPEN, Gtk.ResponseType.OK,
        )

        f = Gtk.FileFilter()
        f.set_name("RPM packages (*.rpm)")
        f.add_pattern("*.rpm")
        dialog.add_filter(f)

        resp = dialog.run()
        if resp == Gtk.ResponseType.OK:
            rpm_path = dialog.get_filename()
            if rpm_path:
                self.run_helper(["install_local_rpm", rpm_path])
        dialog.destroy()


def main():
    win = AlmaDriverManager()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
